{
    "name" : "Market Monitor Dev Container",
    "dockerFile": "../docker/ci-base.Dockerfile",
    "customizations": {
        "vscode": {
            "extensions": ["ms-vscode.cpptools", "ms-vscode.cmake-tools", "twxs.cmake"]
        }
